{
  "name": "@gatekeeper-dev/sdk",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kartik213/Gatekeeper.git"
  },
  "homepage": "https://github.com/Kartik213/Gatekeeper#readme",
  "bugs": {
    "url": "https://github.com/Kartik213/Gatekeeper/issues"
  },
  "description": "Client SDK for Gatekeeper - lightweight feature flag management",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "feature-flags",
    "feature-toggle",
    "sdk"
  ],
  "license": "MIT"
}
